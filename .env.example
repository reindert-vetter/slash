# slash local configuration.
# Copy this to .env (which is gitignored) and adjust the values, or just run
# `go run .` once interactively — on first run it offers to create .env for you.

# Local clone of the target repo, used for all git/worktree operations.
# A leading ~ is expanded to your home directory. Default: ~/dev/plug-and-pay
SLASH_REPO_DIR=~/dev/plug-and-pay

# SQLite DB path (default data/graph.db)
# SLASH_DB=data/graph.db

# Offline/test toggles — set to "off" to avoid touching the network.
# SLASH_GITHUB=off
# SLASH_CLAUDE=off
# SLASH_JIRA=off
